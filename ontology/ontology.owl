         //
         //////////////////////////////////////////////////////////////// -->

    <!-- https://w3id.org/rtskg/ontology/dataproperty/geometry -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/rtskg/ontology/dataproperty/geometry">
        <rdfs:domain rdf:resource="https://w3id.org/rtskg/ontology/class/functional_area"/>
        <rdfs:domain rdf:resource="https://w3id.org/rtskg/ontology/class/borough"/>
        <rdfs:domain rdf:resource="https://w3id.org/rtskg/ontology/class/station_area"/>
        <rdfs:domain rdf:resource="https://w3id.org/rtskg/ontology/class/block"/>
        <rdfs:domain rdf:resource="https://w3id.org/rtskg/ontology/class/road"/>
        <rdfs:domain rdf:resource="https://w3id.org/rtskg/ontology/class/poi"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#wktLiteral"/>
        <rdfs:label>geometry (OGC Well-Known Text, WGS84 lon/lat)</rdfs:label>
    </owl:DatatypeProperty>

    <!-- https://w3id.org/rtskg/ontology/dataproperty/walking_time_minutes -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/rtskg/ontology/dataproperty/walking_time_minutes">
