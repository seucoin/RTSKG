{
  "rnn_units": 200,
  "lambda": 0.0015,
  "bidir_adj_mx": true,

  "scaler": "normal",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "max_epoch": 120,
  "learner": "adam",
  "learning_rate": 0.005,

  "lr_decay": true,
  "lr_scheduler": "steplr",
  "lr_decay_ratio": 0.90,
  "step_size": 25,

  "clip_grad_norm": false,

  "use_early_stop": false,
  "patience": 15
}
