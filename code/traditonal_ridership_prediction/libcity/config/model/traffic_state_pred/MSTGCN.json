{
  "nb_block": 2,
  "K": 2,
  "nb_chev_filter": 32,
  "nb_time_filter": 32,
  "bidir_adj_mx": true,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,
  "train_rate": 0.7,
  "eval_rate": 0.1,

  "max_epoch": 30,
  "learner": "adam",
  "learning_rate": 0.002,

  "lr_decay": true,
  "lr_scheduler": "steplr",
  "lr_decay_ratio": 0.9,
  "step_size": 10,

  "clip_grad_norm": false,
  "use_early_stop": false
}